generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core User ────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String?   @unique
  emailVerified    DateTime?
  image            String?
  createdAt        DateTime  @default(now())

  dailyGoalMinutes Int       @default(30)
  startDate        DateTime  @default(now())
  timezone         String    @default("Europe/Bucharest")

  accounts         Account[]
  sessions         Session[]
  progress         QuestionProgress[]
  learningSessions LearningSession[]
  weeklyPlans      WeeklyPlan[]
  feynmanResponses FeynmanResponse[]
}

// ─── Questions ────────────────────────────────────────────────────────────────

model Question {
  id       Int    @id
  category String
  question String @db.Text
  answer   String @db.Text

  totalAttempts   Int @default(0)
  correctAttempts Int @default(0)

  progress         QuestionProgress[]
  sessionQuestions SessionQuestion[]
  feynmanResponses FeynmanResponse[]

  @@index([category])
}

// ─── Spaced Repetition State ──────────────────────────────────────────────────

model QuestionProgress {
  id         String @id @default(cuid())
  userId     String
  questionId Int

  easeFactor     Float    @default(2.5)
  interval       Int      @default(0)
  repetitions    Int      @default(0)
  nextReviewDate DateTime @default(now())
  lastQuality    Int?

  totalAttempts      Int @default(0)
  correctAttempts    Int @default(0)
  consecutiveCorrect Int @default(0)

  masteryLevel     MasteryLevel @default(NEW)
  feynmanCompleted Int          @default(0)

  lastReviewedAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, nextReviewDate])
  @@index([userId, masteryLevel])
}

// ─── Learning Sessions ────────────────────────────────────────────────────────

model LearningSession {
  id     String @id @default(cuid())
  userId String

  startedAt   DateTime    @default(now())
  endedAt     DateTime?
  sessionType SessionType @default(MIXED)

  questionsAttempted Int  @default(0)
  questionsCorrect   Int  @default(0)
  durationSeconds    Int?

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions SessionQuestion[]

  @@index([userId, startedAt])
}

model SessionQuestion {
  id         String @id @default(cuid())
  sessionId  String
  questionId Int

  userRating      Int
  correct         Boolean
  responseSeconds Float?

  questionIndex Int
  wasReview     Boolean
  reason        QuestionReason @default(NEW)

  createdAt DateTime @default(now())

  session  LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question        @relation(fields: [questionId], references: [id])

  @@index([sessionId, questionIndex])
}

// ─── Feynman Responses ────────────────────────────────────────────────────────

model FeynmanResponse {
  id         String @id @default(cuid())
  userId     String
  questionId Int

  explanation String   @db.Text
  createdAt   DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@index([userId, questionId])
}

// ─── 90-Day Weekly Plans ──────────────────────────────────────────────────────

model WeeklyPlan {
  id         String @id @default(cuid())
  userId     String
  weekNumber Int

  startDate DateTime
  endDate   DateTime

  targetMinutesPerDay   Int
  targetQuestionsPerDay Int
  focusCategories       String[]
  phase                 LearningPhase

  minutesCompleted   Int   @default(0)
  questionsCompleted Int   @default(0)
  daysActive         Int   @default(0)
  avgAccuracy        Float @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekNumber])
  @@index([userId, startDate])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum MasteryLevel {
  NEW
  LEARNING
  FAMILIAR
  PROFICIENT
  MASTERED
}

enum SessionType {
  MIXED
  NEW_ONLY
  REVIEW_ONLY
  WEAK_AREAS
  EXAM_PREP
}

enum QuestionReason {
  NEW
  REVIEW
  WEAK_AREA
  INTERLEAVE
}

enum LearningPhase {
  FOUNDATION
  EXPANSION
  DEEPENING
  MASTERY
}
